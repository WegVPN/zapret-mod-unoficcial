<Window x:Class="ZapretMod.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ZapretMod - DPI Bypass" 
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        MinHeight="600" MinWidth="800">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="25,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="🛡" FontSize="32" Margin="0,0,15,0"/>
                    <StackPanel>
                        <TextBlock Text="ZapretMod" FontSize="24" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="DPI Bypass for Discord, YouTube, Telegram" 
                                   FontSize="12" Foreground="#888888" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusIndicator" Width="12" Height="12" Fill="{StaticResource ErrorBrush}" Margin="0,0,8,0"/>
                    <TextBlock x:Name="StatusText" Text="Остановлено" FontSize="14" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" Grid.RowSpan="2" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="25,20">
                
                <!-- Strategy Selection -->
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="📋 Стратегия обхода" FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,15"/>
                        
                        <ComboBox x:Name="StrategyCombo" 
                                  FontSize="14" 
                                  Padding="12,10"
                                  Background="{StaticResource SurfaceLightBrush}"
                                  Foreground="White"
                                  BorderThickness="0"
                                  Margin="0,0,0,15">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" Foreground="White"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        
                        <TextBlock x:Name="StrategyDescription" 
                                   Text="Выберите стратегию" 
                                   FontSize="13" 
                                   Foreground="#AAAAAA"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                
                <!-- Quick Actions -->
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <CheckBox x:Name="AutoStartCheck" 
                                  Grid.Column="0"
                                  Content="🚀 Автозапуск" 
                                  Foreground="White" 
                                  FontSize="13"
                                  VerticalAlignment="Center"/>
                        
                        <CheckBox x:Name="GameFilterCheck" 
                                  Grid.Column="1"
                                  Content="🎮 Game Filter" 
                                  Foreground="White" 
                                  FontSize="13"
                                  VerticalAlignment="Center"/>
                        
                        <Button x:Name="DiagnosticsBtn"
                                Grid.Column="2"
                                Content="🔍 Диагностика"
                                Style="{StaticResource ModernButton}"
                                Background="{StaticResource SurfaceLightBrush}"
                                HorizontalAlignment="Right"/>
                    </Grid>
                </Border>
                
                <!-- Log Output -->
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="📜 Логи" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button x:Name="ClearLogBtn" Content="🗑 Очистить" 
                                        Style="{StaticResource ModernButton}"
                                        Background="{StaticResource SurfaceLightBrush}"
                                        Padding="12,6" Margin="0,0,10,0"/>
                                <Button x:Name="SaveLogBtn" Content="💾 Сохранить" 
                                        Style="{StaticResource ModernButton}"
                                        Background="{StaticResource SurfaceLightBrush}"
                                        Padding="12,6"/>
                            </StackPanel>
                        </Grid>
                        
                        <Border Background="#1A1A1A" CornerRadius="8" Padding="15" Height="200">
                            <TextBox x:Name="LogBox" 
                                     IsReadOnly="True"
                                     Background="Transparent"
                                     Foreground="#00FF00"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     BorderThickness="0"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Border>
                
            </StackPanel>
        </ScrollViewer>
        
        <!-- Footer with Start/Stop Button -->
        <Border Grid.Row="3" Background="{StaticResource SurfaceBrush}" Padding="25,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="SettingsBtn" 
                            Content="⚙ Настройки"
                            Style="{StaticResource ModernButton}"
                            Background="{StaticResource SurfaceLightBrush}"
                            Padding="16,12"
                            Margin="0,0,10,0"/>
                    
                    <Button x:Name="ServiceBtn" 
                            Content="🔧 Служба"
                            Style="{StaticResource ModernButton}"
                            Background="{StaticResource SurfaceLightBrush}"
                            Padding="16,12"/>
                </StackPanel>
                
                <Button x:Name="ToggleButton" 
                        Grid.Column="1"
                        Content="▶ ЗАПУСТИТЬ"
                        Style="{StaticResource ModernButton}"
                        FontSize="16"
                        Padding="40,16"
                        Click="ToggleButton_Click"/>
            </Grid>
        </Border>
        
    </Grid>
</Window>

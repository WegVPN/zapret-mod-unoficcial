<Window x:Class="ZapretMod.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="ZapretMod v3.0" Height="720" Width="1000" WindowStartupLocation="CenterScreen" Background="{StaticResource BgBrush}">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="25,20">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Border Background="{StaticResource PrimaryBrush}" CornerRadius="10" Width="45" Height="45">
                        <TextBlock Text="🛡" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="ZapretMod" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="DPI Bypass для Discord, YouTube, Telegram" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="12" Height="12" Fill="{StaticResource ErrorBrush}" Margin="0,0,8,0"/>
                    <TextBlock x:Name="StatusText" Text="Остановлено" FontSize="14" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
        <ScrollViewer Grid.Row="1" Padding="25" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="📋 Стратегия обхода" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,12"/>
                        <ComboBox x:Name="StrategyCombo" Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextBrush}" Padding="12,10" Margin="0,0,0,10" FontSize="14"/>
                        <Border Background="{StaticResource BgBrush}" CornerRadius="8" Padding="12" BorderBrush="#404050" BorderThickness="1">
                            <TextBlock x:Name="StrategyDesc" Text="" FontSize="13" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Border>
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="⚙ Опции" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,12"/>
                            <CheckBox x:Name="AutoStartCheck" Content="Автозапуск с Windows" Foreground="{StaticResource TextBrush}" FontSize="13" Margin="0,6"/>
                            <CheckBox x:Name="OptimizeCheck" Content="🚀 Оптимизация интернета (DNS + TCP)" Foreground="{StaticResource TextBrush}" FontSize="13" Margin="0,6" IsChecked="True"/>
                            <CheckBox x:Name="TrayCheck" Content="Сворачивать в трей" Foreground="{StaticResource TextBrush}" FontSize="13" Margin="0,6" IsChecked="True"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="🔧 Действия" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,12"/>
                            <Button Content="🔍 Диагностика" Style="{StaticResource Btn}" Margin="0,0,0,8" Click="DiagClick" Background="{StaticResource SurfaceBrush}"/>
                            <Button Content="📥 Скачать файлы" Style="{StaticResource Btn}" Click="DownloadClick" Background="{StaticResource SurfaceBrush}"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="📜 Логи работы" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Grid.Column="0"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="🗑 Очистить" Style="{StaticResource Btn}" Padding="12,8" Margin="0,0,8,0" Click="ClearClick" Background="{StaticResource SurfaceBrush}"/>
                                <Button Content="💾 Сохранить" Style="{StaticResource Btn}" Padding="12,8" Click="SaveClick" Background="{StaticResource SurfaceBrush}"/>
                            </StackPanel>
                        </Grid>
                        <Border Background="#151520" CornerRadius="8" Padding="12" Height="220" BorderBrush="#303040" BorderThickness="1">
                            <TextBox x:Name="LogBox" IsReadOnly="True" Background="Transparent" Foreground="#00FF88" FontFamily="Consolas" FontSize="11" BorderThickness="0" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" Padding="25,20">
            <Grid>
                <Button Content="⚙ Настройки" Style="{StaticResource Btn}" Padding="18,12" HorizontalAlignment="Left" Click="SettingsClick" Background="{StaticResource SurfaceBrush}"/>
                <Button x:Name="ToggleBtn" Content="▶ ЗАПУСТИТЬ" Style="{StaticResource Btn}" FontSize="16" Padding="50,18" HorizontalAlignment="Right" Click="ToggleClick"/>
            </Grid>
        </Border>
    </Grid>
</Window>

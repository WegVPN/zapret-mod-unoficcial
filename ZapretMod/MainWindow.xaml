<Window x:Class="ZapretMod.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ZapretMod - DPI Bypass" 
        Height="750" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        MinHeight="700" MinWidth="1000">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}">
            <Grid Margin="30,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Border Background="{StaticResource PrimaryBrush}" CornerRadius="10" Width="50" Height="50">
                        <TextBlock Text="🛡" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="ZapretMod" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="DPI Bypass для Discord, YouTube, Telegram" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
                
                <Border Grid.Column="1" Background="{StaticResource SurfaceHoverColor}" CornerRadius="20" Padding="20,10">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="StatusIndicator" Width="12" Height="12" Fill="{StaticResource ErrorBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="StatusText" Text="Остановлено" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
        
        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="30,25">
            <StackPanel>
                
                <!-- Strategy Card -->
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="25" Margin="0,0,0,20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="📋" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Стратегия обхода" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <ComboBox x:Name="StrategyCombo" 
                                  Style="{StaticResource ModernComboBox}"
                                  Margin="0,0,0,15">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        
                        <Border Background="{StaticResource BackgroundBrush}" CornerRadius="8" Padding="15" Margin="0,0,0,10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💡" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="StrategyDescription" 
                                           Text="Выберите стратегию" 
                                           FontSize="13" 
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
                
                <!-- Options Card -->
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="25" Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <TextBlock Text="⚙" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Опции" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <CheckBox x:Name="AutoStartCheck" 
                                      Content="Автозапуск с Windows" 
                                      Style="{StaticResource ModernCheckBox}"/>
                            
                            <CheckBox x:Name="GameFilterCheck" 
                                      Content="Game Filter (UDP >1023)" 
                                      Style="{StaticResource ModernCheckBox}"/>
                            
                            <CheckBox x:Name="MinimizeToTrayCheck" 
                                      Content="Сворачивать в трей" 
                                      Style="{StaticResource ModernCheckBox}"
                                      IsChecked="True"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <TextBlock Text="🔧" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Действия" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <Button x:Name="DiagnosticsBtn"
                                    Content="🔍 Диагностика"
                                    Style="{StaticResource SecondaryButton}"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,0,0,10"/>
                            
                            <Button x:Name="ServiceBtn"
                                    Content="🔧 Управление службой"
                                    Style="{StaticResource SecondaryButton}"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,0,0,10"/>
                            
                            <Button x:Name="DownloadBinariesBtn"
                                    Content="📥 Скачать файлы"
                                    Style="{StaticResource SecondaryButton}"
                                    HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <!-- Log Card -->
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="25">
                    <StackPanel>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="📜" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Логи работы" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button x:Name="ClearLogBtn" 
                                        Content="🗑 Очистить" 
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="15,8" 
                                        Margin="0,0,10,0"/>
                                <Button x:Name="SaveLogBtn" 
                                        Content="💾 Сохранить" 
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="15,8"/>
                            </StackPanel>
                        </Grid>
                        
                        <Border Background="#151520" CornerRadius="8" Padding="15" Height="250" BorderBrush="#303040" BorderThickness="1">
                            <TextBox x:Name="LogBox" 
                                     IsReadOnly="True"
                                     Background="Transparent"
                                     Foreground="#00FF88"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     BorderThickness="0"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Border>
                
            </StackPanel>
        </ScrollViewer>
        
        <!-- Footer with Start/Stop Button -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" Padding="30,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="SettingsBtn" 
                            Content="⚙ Настройки"
                            Style="{StaticResource SecondaryButton}"
                            Padding="20,14"/>
                </StackPanel>
                
                <Button x:Name="ToggleButton" 
                        Grid.Column="1"
                        Content="▶ ЗАПУСТИТЬ"
                        Style="{StaticResource ModernButton}"
                        FontSize="16"
                        FontWeight="Bold"
                        Padding="60,20"
                        Click="ToggleButton_Click"/>
            </Grid>
        </Border>
        
    </Grid>
</Window>

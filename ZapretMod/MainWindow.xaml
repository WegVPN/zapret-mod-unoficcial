<Window x:Class="ZapretMod.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ZapretMod - DPI Bypass" 
        Height="720" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        MinHeight="650" MinWidth="900">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="25,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="🛡" FontSize="36" Margin="0,0,15,0"/>
                    <StackPanel>
                        <TextBlock Text="ZapretMod" FontSize="26" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="DPI Bypass для Discord, YouTube, Telegram" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,3,0,0"/>
                    </StackPanel>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusIndicator" Width="14" Height="14" Fill="{StaticResource ErrorBrush}" Margin="0,0,10,0"/>
                    <TextBlock x:Name="StatusText" Text="Остановлено" FontSize="15" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="25,20">
            <StackPanel>
                
                <!-- Strategy Card -->
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="25" Margin="0,0,0,20" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="📋 Стратегия обхода" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,15"/>
                        
                        <ComboBox x:Name="StrategyCombo" 
                                  Style="{StaticResource ModernComboBox}"
                                  Margin="0,0,0,15">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        
                        <Border Background="{StaticResource BackgroundBrush}" CornerRadius="6" Padding="15" Margin="0,0,0,10">
                            <TextBlock x:Name="StrategyDescription" 
                                       Text="Выберите стратегию" 
                                       FontSize="13" 
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Border>
                
                <!-- Options Card -->
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="25" Margin="0,0,0,20" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                            <TextBlock Text="⚙ Опции" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,15"/>
                            
                            <CheckBox x:Name="AutoStartCheck" 
                                      Content="Автозапуск с Windows" 
                                      Foreground="{StaticResource TextPrimaryBrush}" 
                                      FontSize="13"
                                      Margin="0,0,0,12"/>
                            
                            <CheckBox x:Name="GameFilterCheck" 
                                      Content="Game Filter (UDP >1023)" 
                                      Foreground="{StaticResource TextPrimaryBrush}" 
                                      FontSize="13"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="🔧 Действия" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,15"/>
                            
                            <Button x:Name="DiagnosticsBtn"
                                    Content="🔍 Диагностика"
                                    Style="{StaticResource SecondaryButton}"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,0,0,10"/>
                            
                            <Button x:Name="ServiceBtn"
                                    Content="🔧 Управление службой"
                                    Style="{StaticResource SecondaryButton}"
                                    HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <!-- Log Card -->
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="25" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="📜 Логи работы" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button x:Name="ClearLogBtn" 
                                        Content="🗑 Очистить" 
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="15,8" 
                                        Margin="0,0,10,0"/>
                                <Button x:Name="SaveLogBtn" 
                                        Content="💾 Сохранить" 
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="15,8"/>
                            </StackPanel>
                        </Grid>
                        
                        <Border Background="#1A1A1A" CornerRadius="6" Padding="15" Height="220" BorderBrush="#333" BorderThickness="1">
                            <TextBox x:Name="LogBox" 
                                     IsReadOnly="True"
                                     Background="Transparent"
                                     Foreground="#4AF626"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     BorderThickness="0"
                                     VerticalScrollBarVisibility="Auto"
                                     TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Border>
                
            </StackPanel>
        </ScrollViewer>
        
        <!-- Footer with Start/Stop Button -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="25,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="SettingsBtn" 
                            Content="⚙ Настройки"
                            Style="{StaticResource SecondaryButton}"
                            Padding="18,12"/>
                </StackPanel>
                
                <Button x:Name="ToggleButton" 
                        Grid.Column="1"
                        Content="▶ ЗАПУСТИТЬ"
                        Style="{StaticResource ModernButton}"
                        FontSize="16"
                        FontWeight="Bold"
                        Padding="50,18"
                        Click="ToggleButton_Click"/>
            </Grid>
        </Border>
        
    </Grid>
</Window>

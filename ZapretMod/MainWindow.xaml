<Window x:Class="ZapretMod.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ZapretMod v3.0" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="20">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🛡 ZapretMod" FontSize="24" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text=" - DPI Bypass для Discord, YouTube, Telegram" FontSize="14" Foreground="#A0A0B0" Margin="10,5,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Ellipse x:Name="StatusIndicator" Width="12" Height="12" Fill="{StaticResource ErrorBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusText" Text="Остановлено" FontSize="14" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel>
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="📋 Стратегия" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                        <ComboBox x:Name="StrategyCombo" Background="{StaticResource SurfaceBrush}" Foreground="White" Padding="10" Margin="0,0,0,10"/>
                        <TextBlock x:Name="StrategyDesc" Text="" Foreground="#A0A0B0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="⚙ Опции" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                            <CheckBox x:Name="AutoStartCheck" Content="Автозапуск" Foreground="White" Margin="0,5"/>
                            <CheckBox x:Name="OptimizeCheck" Content="🚀 Оптимизация интернета" Foreground="White" Margin="0,5"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="🔧 Действия" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                            <Button Content="🔍 Диагностика" Style="{StaticResource ModernButton}" Margin="0,5" Click="DiagnosticsClick"/>
                            <Button Content="📥 Скачать файлы" Style="{StaticResource ModernButton}" Margin="0,5" Click="DownloadClick"/>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="8" Padding="20">
                    <StackPanel>
                        <TextBlock Text="📜 Логи" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                        <TextBox x:Name="LogBox" Height="200" Background="#151520" Foreground="#00FF88" FontFamily="Consolas" IsReadOnly="True" VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" Padding="20">
            <Grid>
                <Button Content="⚙ Настройки" Style="{StaticResource ModernButton}" Padding="20,12" HorizontalAlignment="Left" Click="SettingsClick"/>
                <Button x:Name="ToggleButton" Content="▶ ЗАПУСТИТЬ" Style="{StaticResource ModernButton}" FontSize="16" Padding="50,18" HorizontalAlignment="Right" Click="ToggleClick"/>
            </Grid>
        </Border>
    </Grid>
</Window>
